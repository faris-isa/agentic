{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@rama_nigg/open-cursor",
    "cursor-acp",
    "oh-my-openagent"
  ],
  "mcp": {
    "postgres": {
      "type": "local",
      "enabled": false,
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "environment": {
        "DATABASE_URI": "postgresql://USER:PASSWORD@HOST:5432/DATABASE"
      }
    },
    "postgres-local": {
      "type": "local",
      "enabled": false,
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "DATABASE_URI",
